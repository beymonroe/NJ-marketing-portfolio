# MONGODB_URL: The connection string for your MongoDB Atlas database.
# Note: Since this is a sensitive database credential, it is kept secure on the server side.
MONGODB_URL=

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=

